\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces Final Stage-2 iterative best-response diagnostics across three independent seeds. The columns UNIFORM, SPREAD, and $D_k$ report post-update means $\mathbb  {E}_{\rho _U}[\tau (\pi _k)]$, $\mathbb  {E}_{\rho _{\mathrm  {stress}}}[\tau (\pi _k)]$, and $\mathbb  {E}_{\rho _k}[\tau (\pi _k)]$. The diagnostic columns are computed from both pre- and post-update evaluations: $\textsf  {defender\_adversarial}_k=\mathbb  {E}_{\rho _k}[\tau (\pi _{k-1})]-\mathbb  {E}_{\rho _U}[\tau (\pi _{k-1})]$, $\textsf  {attacker\_adaptation}_k=\mathbb  {E}_{\rho _k}[\tau (\pi _k)]-\mathbb  {E}_{\rho _k}[\tau (\pi _{k-1})]$, and $\textsf  {uniform\_drift}_k=\mathbb  {E}_{\rho _U}[\tau (\pi _k)]-\mathbb  {E}_{\rho _U}[\tau (\pi _{k-1})]$. Defender budgets are restricted to 50k steps per generation, with 100 scripted episodes per mode and 50 pre-update $D_k$ episodes.}}{10}{table.caption.2}\protected@file@percent }
\newlabel{tab:ibr}{{2}{10}{Final Stage-2 iterative best-response diagnostics across three independent seeds. The columns UNIFORM, SPREAD, and $D_k$ report post-update means $\E _{\rho _U}[\tauT (\pi _k)]$, $\E _{\rhoStress }[\tauT (\pi _k)]$, and $\E _{\rho _k}[\tauT (\pi _k)]$. The diagnostic columns are computed from both pre- and post-update evaluations: $\textsf {defender\_adversarial}_k=\E _{\rho _k}[\tauT (\pi _{k-1})]-\E _{\rho _U}[\tauT (\pi _{k-1})]$, $\textsf {attacker\_adaptation}_k=\E _{\rho _k}[\tauT (\pi _k)]-\E _{\rho _k}[\tauT (\pi _{k-1})]$, and $\textsf {uniform\_drift}_k=\E _{\rho _U}[\tauT (\pi _k)]-\E _{\rho _U}[\tauT (\pi _{k-1})]$. Defender budgets are restricted to 50k steps per generation, with 100 scripted episodes per mode and 50 pre-update $D_k$ episodes}{table.caption.2}{}}
